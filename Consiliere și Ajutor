    <h1>Consiliere și Ajutor</h1>
    <p>Lasă-ne datele tale și te vom contacta confidențial.</p>
  </section>

  <section class="content">
    <div class="container">
      <form id="consiliereForm">
        <input type="text" id="c_name" placeholder="Nume complet" required>
        <input type="email" id="c_email" placeholder="Email" required>
        <input type="tel" id="c_phone" placeholder="Telefon (opțional)">
        <textarea id="c_message" rows="5" placeholder="Mesajul tău..." required></textarea>
        <button type="submit" class="btn-primary">Trimite cererea</button>
      </form>
      <p id="consiliereMessage"></p>
    </div>
  </section>

